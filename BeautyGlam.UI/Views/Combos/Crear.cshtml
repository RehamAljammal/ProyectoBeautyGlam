@model BeautyGlam.Abstracciones.ModelosParaUI.ComboPromocionalDTO

@{
    ViewBag.Title = "Crear combo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space promo-page">
    <div class="container promo-container">

        <div class="promo-header">
            <h2 class="promo-title">Crear combo promocional</h2>
            <p class="promo-subtitle">Selecciona productos para el combo</p>
        </div>

        @using (Html.BeginForm("Crear", "Combos", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="promo-card p-4">

                <div class="mb-3">
                    @Html.LabelFor(m => m.titulo)
                    @Html.TextBoxFor(m => m.titulo, new { @class = "form-control prod-input" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.descripcion)
                    @Html.TextAreaFor(m => m.descripcion, new { @class = "form-control prod-input", rows = 3 })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.descuento)
                    @Html.TextBoxFor(m => m.descuento,
                        new { @class = "form-control prod-input", type = "number", step = "0.01" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.fechaInicio)
                        @Html.TextBoxFor(m => m.fechaInicio,
                            new { @class = "form-control prod-input", type = "date" })
                    </div>

                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.fechaFin)
                        @Html.TextBoxFor(m => m.fechaFin,
                            new { @class = "form-control prod-input", type = "date" })
                    </div>
                </div>

                <hr />

                <h5>Productos del combo</h5>

                <!-- BUSCADOR -->
                <div class="mb-3">

                    <input type="text"
                           id="buscarProducto"
                           class="form-control prod-input"
                           placeholder="Buscar o seleccionar producto..."
                           onclick="mostrarProductos()"
                           onkeyup="filtrarProductos()" />

                    <div id="listaProductos" class="picker-list mt-2"></div>

                </div>

                <!-- PRODUCTOS SELECCIONADOS -->
                <div class="mt-4">
                    <h6>Productos agregados</h6>
                    <div id="productosSeleccionados"></div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="promo-btn">
                        Guardar combo
                    </button>

                    <a href="@Url.Action("Index","Combos")"
                       class="promo-btn promo-btn-outline">
                        Cancelar
                    </a>
                </div>

            </div>
        }

    </div>
</section>

<style>

    .picker-list {
        max-height: 260px;
        overflow: auto;
    }

    .pick-item {
        border: 1px solid #ead7f3;
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 8px;
        cursor: pointer;
        background: white;
    }

        .pick-item:hover {
            background: #faf6ff;
        }

    .pick-name {
        font-weight: 700;
        color: #5c3b6f;
    }

    .pick-precio {
        font-size: 13px;
        color: #6b4c7a;
    }
</style>

<script>

var productos = [

@foreach (var p in Model.productosDisponibles)
{
<text>
{
id:"@p.id",
nombre:"@p.nombre",
precio:"@p.precio"
},
</text>
}

];

function mostrarProductos(){

renderLista(productos);

}

function filtrarProductos(){

var texto = document.getElementById("buscarProducto").value.toLowerCase();

var filtrados = productos.filter(function(p){

return p.nombre.toLowerCase().includes(texto);

});

renderLista(filtrados);

}

function renderLista(lista){

var contenedor = document.getElementById("listaProductos");

contenedor.innerHTML="";

lista.forEach(function(p){

var div = document.createElement("div");

div.className="pick-item";

div.innerHTML =
'<div class="pick-name">'+p.nombre+'</div>'+
'<div class="pick-precio">₡ '+p.precio+'</div>';

div.onclick=function(){

agregarProducto(p);

};

contenedor.appendChild(div);

});

}

function agregarProducto(p){

var contenedor = document.getElementById("productosSeleccionados");

var html =
'<div class="pick-item">'+
'<div class="pick-name">'+p.nombre+'</div>'+
'<div class="pick-precio">₡ '+p.precio+'</div>'+

'<input type="hidden" name="idsProductos" value="'+p.id+'">'+

'<button type="button" class="promo-btn promo-btn-outline mt-2" onclick="this.parentElement.remove()">Quitar</button>'+
'</div>';

contenedor.insertAdjacentHTML("beforeend",html);

}

</script>