@model BeautyGlam.Abstracciones.ModelosParaUI.ComboPromocionalDTO

@{
    ViewBag.Title = "Editar combo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space promo-page">
    <div class="container promo-container">

        <div class="promo-header">
            <h2 class="promo-title">Editar combo</h2>
            <p class="promo-subtitle">Modificar información</p>
        </div>

        @using (Html.BeginForm("Editar", "Combos", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @Html.HiddenFor(m => m.idCombo)

            <div class="promo-card p-4">

                <div class="mb-3">
                    @Html.LabelFor(m => m.titulo)
                    @Html.TextBoxFor(m => m.titulo, new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.descripcion)
                    @Html.TextAreaFor(m => m.descripcion, new { @class = "form-control", rows = 3 })
                </div>

                <!-- DESCUENTO -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.descuento)
                    @Html.TextBoxFor(m => m.descuento,
                        new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                </div>

                <hr />

                <h6>Productos del combo</h6>

                <table class="table table-sm promo-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Precio</th>
                        </tr>
                    </thead>
                    <tbody>

                        @if (Model.productos != null && Model.productos.Any())
                        {
                            for (int i = 0; i < Model.productos.Count; i++)
                            {
                                <tr>
                                    <td>
                                        @Model.productos[i].nombre

                                        <!-- ESTE ES EL QUE HACE QUE SE GUARDE -->
                                        <input type="hidden"
                                               name="idsProductos"
                                               value="@Model.productos[i].id_Producto" />

                                    </td>
                                    <td class="text-end">
                                        ₡ @Model.productos[i].precio
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted">
                                    No hay productos en este combo.
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>

                <div class="d-flex justify-content-between mt-3">
                    <strong>Total sin descuento:</strong>
                    <strong>₡ @Model.precioCombo</strong>
                </div>

                <div class="d-flex justify-content-between mt-1">
                    <strong>Total con descuento:</strong>
                    <strong>₡ @Model.totalConDescuento</strong>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="promo-btn">
                        Guardar cambios
                    </button>

                    <a href="@Url.Action("Index","Combos")"
                       class="promo-btn promo-btn-outline">
                        Cancelar
                    </a>
                </div>

            </div>
        }

    </div>
</section>