@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.ComboPromocionalDTO>

@{
    ViewBag.Title = "Combos Promocionales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space promo-page">
    <div class="container promo-container">

        <div class="promo-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="promo-title">Combos promocionales</h2>
                <p class="promo-subtitle">Ofertas combinadas 💖</p>
            </div>

            <!-- SIN ROLES -->
            <a href="@Url.Action("Crear","Combos")" class="promo-btn">
                + Nuevo combo
            </a>
        </div>

        <div class="row">

            @if (Model != null && Model.Any())
            {
                foreach (var combo in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">

                        <div class="promo-card h-100">

                            <div class="promo-card-head">
                                <div>
                                    <span class="promo-badge">Combo</span>
                                </div>
                            </div>

                            <div class="p-3">

                                <h5 style="color:#5c3b6f; font-weight:600;">
                                    @combo.titulo
                                </h5>

                                <p class="text-muted mb-3">
                                    @combo.descripcion
                                </p>

                                <div class="promo-table-wrap">

                                    <table class="table table-sm align-middle promo-table mb-2">
                                        <thead>
                                            <tr>
                                                <th>Artículo</th>
                                                <th class="text-end">Precio</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @if (combo.productos != null && combo.productos.Any())
                                            {
                                                foreach (var producto in combo.productos)
                                                {
                                                    <tr>
                                                        <td>@producto.nombre</td>
                                                        <td class="text-end">₡ @producto.precio</td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="2" class="text-center text-muted">
                                                        No hay productos asociados a este combo
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <strong style="color:#5c3b6f;">
                                        Total del combo
                                    </strong>

                                    <strong style="font-size:1.1rem;">
                                        ₡ @combo.precioCombo
                                    </strong>
                                </div>

                                <!-- SIN ROLES -->
                                <div class="promo-actions text-end mt-3">

                                    <a href="@Url.Action("Editar","Combos", new { id = combo.idCombo })"
                                       class="promo-btn promo-btn-outline promo-btn-sm">
                                        Editar ✏️
                                    </a>

                                    <a href="@Url.Action("Eliminar","Combos", new { id = combo.idCombo })"
                                       class="promo-btn promo-btn-danger promo-btn-sm">
                                        Eliminar 🗑️
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    No hay combos disponibles.
                </div>
            }

        </div>

    </div>
</section>