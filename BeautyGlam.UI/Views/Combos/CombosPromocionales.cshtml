@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.ComboPromocionalDTO>

@{
    ViewBag.Title = "Combos Promocionales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space promo-page">
    <div class="container promo-container">

        <!-- ENCABEZADO -->
        <div class="promo-header d-flex align-items-center mb-4">

            <div class="flex-grow-1 text-center">
                <h2 class="promo-title">Combos promocionales</h2>
                <p class="promo-subtitle">Ofertas combinadas 💖</p>
            </div>

            <div>
                @if (Session["Rol"]?.ToString() == "Admin")
                {
                    <a href="@Url.Action("Crear","Combos")" class="promo-btn">
                        + Nuevo combo
                    </a>
                }
            </div>

        </div>

        <!-- LISTADO -->
        <div class="row justify-content-center">

            @if (Model != null && Model.Any())
            {
                foreach (var combo in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">

                        <div class="promo-card h-100">

                            <div class="promo-card-head">
                                <span class="promo-badge">Combo</span>
                            </div>

                            <div class="p-3">

                                <h5 style="color:#5c3b6f; font-weight:600;">
                                    @combo.titulo
                                </h5>

                                <p class="text-muted mb-3">
                                    @combo.descripcion
                                </p>

                                <div class="promo-table-wrap">

                                    <table class="table table-sm align-middle promo-table mb-2">
                                        <thead>
                                            <tr>
                                                <th>Artículo</th>
                                                <th class="text-end">Precio</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @if (combo.productos != null && combo.productos.Any())
                                            {
                                                foreach (var producto in combo.productos)
                                                {
                                                    <tr>
                                                        <td class="d-flex align-items-center gap-2">

                                                            <img src="@producto.imagen"
                                                                 alt="@producto.nombre"
                                                                 style="width:38px;height:38px;object-fit:cover;border-radius:6px;" />

                                                            <span>@producto.nombre</span>

                                                        </td>

                                                        <td class="text-end">
                                                            ₡ @producto.precio
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="2" class="text-center text-muted">
                                                        No hay productos asociados a este combo
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                </div>

                                <!-- Totales -->
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span><strong>Total sin descuento</strong></span>
                                    <span><strong>₡ @combo.precioCombo</strong></span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-1">
                                    <span><strong>Descuento</strong></span>
                                    <span>₡ @combo.descuento</span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-1">
                                    <span style="color:#5c3b6f;">
                                        <strong>Total con descuento</strong>
                                    </span>
                                    <span style="font-size:1.1rem;">
                                        <strong>₡ @combo.totalConDescuento</strong>
                                    </span>
                                </div>

                                <!-- ACCIONES -->
                                <div class="promo-actions text-end mt-3">

                                    @if (Session["Rol"]?.ToString() == "Admin")
                                    {
                                        <a href="@Url.Action("Editar","Combos", new { id = combo.idCombo })"
                                           class="promo-btn promo-btn-outline promo-btn-sm">
                                            Editar ✏️
                                        </a>

                                        <a href="@Url.Action("Eliminar","Combos", new { id = combo.idCombo })"
                                           class="promo-btn promo-btn-danger promo-btn-sm">
                                            Eliminar 🗑️
                                        </a>
                                    }
                                    else if (Session["IdUsuario"] != null)
                                    {
                                        <button class="cat-btn cat-btn-soft"
                                                onclick="agregarWishlist(@combo.idCombo, this)">
                                            Agregar a favoritos ♡
                                        </button>
                                            }
                                    else
                                    {
                                        <a href="@Url.Action("Login","Cuenta")"
                                           class="promo-btn">
                                            Inicia sesión ❤️
                                        </a>
                                    }

                                </div>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    No hay combos disponibles.
                </div>
            }

        </div>

    </div>

    <script>

        function agregarWishlist(idCombo, boton) {

            fetch('/Wishlist/Agregar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'idProducto=' + idCombo
            })
                .then(r => r.json())
                .then(data => {

                    if (data.login) {
                        window.location = "/Cuenta/Login";
                        return;
                    }

                    if (data.ok) {

                        boton.innerHTML = "❤️ En favoritos";
                        boton.disabled = true;

                    }

                });

        }

    </script>
</section>