@model List<BeautyGlam.Abstracciones.ModelosParaUI.ReporteVentasDto>

@{
    ViewBag.Title = "Resultado Reporte";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space inv-page">
    <div class="container inv-container">

        <!-- HEADER -->
        <div class="inv-header">
            <h2 class="inv-title">Resultado del Reporte 📊</h2>
            <p class="inv-subtitle">
                Visualización detallada de ventas
            </p>
        </div>

        <div class="inv-card">

            <div class="inv-card-head">
                <span class="inv-badge">Ventas</span>
                <h5 class="inv-card-title">Listado generado</h5>
            </div>

            <div class="inv-card-body">

                @if (Model == null || !Model.Any())
                {
                    <div class="text-center p-4">
                        <h5 style="color:#c75b5b;">No hay datos para mostrar 🚫</h5>
                        <p class="text-muted">
                            Intenta seleccionar otro rango de fechas.
                        </p>
                    </div>
                }
                else
                {
                    var totalGeneral = Model.Sum(x => x.Total);

                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td>@item.Cliente</td>
                                        <td class="text-end">
                                            ₡@item.Total.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- TOTAL GENERAL -->
                    <div class="text-end mt-4">
                        <div class="sup-total-box">
                            <h5>Total General</h5>
                            <h3 style="color:#5c3b6f;">
                                ₡@totalGeneral.ToString("N2")
                            </h3>
                        </div>
                    </div>
                }

                <!-- BOTONES -->
                <div class="inv-center-actions mt-4">

                    @using (Html.BeginForm("ExportarPDF", "Reporte", FormMethod.Get))
                    {
                        <input type="hidden" name="FechaInicio" value="@Request["FechaInicio"]" />
                        <input type="hidden" name="FechaFin" value="@Request["FechaFin"]" />

                        <button type="submit" class="btn inv-btn">
                            Exportar PDF 📄
                        </button>
                    }

                    <a href="@Url.Action("Ventas","Reporte")"
                       class="btn inv-btn inv-btn-soft">
                        Nuevo Reporte ⬅️
                    </a>

                </div>

            </div>
        </div>

    </div>
</section>