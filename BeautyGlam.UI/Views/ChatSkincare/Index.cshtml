@{
    ViewBag.Title = "Chat Skincare";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .chat-box {
        max-height: 350px;
        overflow-y: auto;
        padding: 15px;
        background: #faf7fd;
        border-radius: 12px;
        border: 1px solid #eadff3;
    }

    .chat-msg {
        margin-bottom: 12px;
        display: flex;
    }

        .chat-msg.user {
            justify-content: flex-end;
        }

    .chat-bubble {
        max-width: 75%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 14px;
    }

        .chat-bubble.user {
            background: linear-gradient(135deg, #ffb7d5, #cdb7ff);
            color: white;
        }

        .chat-bubble.bot {
            background: #f1e9fb;
            color: #5c3b6f;
        }

    .chat-input {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }
</style>

<section class="section-space sup-page">
    <div class="container sup-container">

        <!-- HEADER -->
        <div class="sup-header">
            <h2 class="sup-title">Chat de Skincare 💬</h2>
            <p class="sup-subtitle">
                Pregunta sobre tu piel y recibe recomendaciones inteligentes ✨
            </p>
        </div>

        <!-- CARD -->
        <div class="sup-card">

            <div class="sup-card-head">
                <span class="sup-badge">Asistente</span>
            </div>

            <!-- CHAT -->
            <div style="padding:15px;">

                <div class="chat-box">

                    @if (ViewBag.Pregunta != null)
                    {
                        <div class="chat-msg user">
                            <div class="chat-bubble user">
                                @ViewBag.Pregunta
                            </div>
                        </div>
                    }

                    @if (ViewBag.Respuesta != null)
                    {
                        <div class="chat-msg">
                            <div class="chat-bubble bot">
                                @ViewBag.Respuesta
                            </div>
                        </div>
                    }

                </div>

                <!-- INPUT -->
                @using (Html.BeginForm("Preguntar", "ChatSkincare", FormMethod.Post))
                {
                    <div class="chat-input">

                        <input type="text"
                               name="mensaje"
                               class="form-control"
                               placeholder="Ej: Tengo acné y piel grasa"
                               required />

                        <button type="submit" class="sup-btn">
                            Enviar ✨
                        </button>

                    </div>
                }

            </div>

        </div>

    </div>
</section>