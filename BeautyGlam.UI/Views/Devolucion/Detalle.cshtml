@model BeautyGlam.Abstracciones.ModelosParaUI.DevolucionListadoDto

@{
    ViewBag.Title = "DetalleDevolucion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space prod-page">
    <div class="container prod-container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-9">

                <div class="prod-card">
                    <div class="prod-card-head">
                        <div><span class="prod-badge">Detalle</span></div>
                        <a href="@Url.Action("Listado","Devolucion")" class="prod-btn prod-btn-soft">Volver</a>
                    </div>

                    <div class="p-4">
                        <h2 style="color:#5c3b6f; font-weight:900;">
                            Devolución
                        </h2>

                        <div class="mt-2 mb-3">
                            @if (Model.estado == "Registrada")
                            {
                                <span class="prod-chip prod-chip-ok">Registrada</span>
                            }
                            else
                            {
                                <span class="prod-chip prod-chip-off">@Model.estado</span>
                            }
                        </div>

                        <p style="color:#6b4c7a; font-weight:650;">
                            <strong>Motivo:</strong> @Model.motivo
                        </p>

                        <hr />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <p><strong>Fecha:</strong> @Model.fecha.ToShortDateString()</p>
                            </div>
                        </div>

                        <div class="mt-3">
                            <p><strong>Observación:</strong></p>
                            <div class="p-3" style="background:#f8f4fb; border-radius:12px;">
                                @Model.observacion
                            </div>
                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
</section>