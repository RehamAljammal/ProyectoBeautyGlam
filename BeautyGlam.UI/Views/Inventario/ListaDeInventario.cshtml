@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.InventarioDto>

@{
    ViewBag.Title = "Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .inv-chip-warning {
        background: #fff4cc;
        color: #b38b00;
        padding: 6px 10px;
        border-radius: 20px;
    }

    .usr-pagination {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 18px;
    }

    .usr-page-link {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        color: #6b4c7a;
        background: #f6f1fb;
        border: 1px solid #eadff3;
        transition: .2s ease;
    }

        .usr-page-link:hover {
            background: #efe6fa;
            transform: translateY(-1px);
        }

        .usr-page-link.active {
            background: linear-gradient(135deg,#ffb7d5,#cdb7ff);
            color: white;
            border: none;
        }
</style>

<section class="section-space inv-page">
    <div class="container inv-container">

        <div class="inv-header">
            <h2 class="inv-title">Inventario</h2>
            <p class="inv-subtitle">Controla stock y mínimos/máximos ✨</p>
        </div>

        <div style="padding:15px;">
            <form method="get" action="@Url.Action("ListaDeInventario","Inventario")">
                <div class="d-flex gap-2">
                    <input type="text"
                           name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control"
                           placeholder="Buscar producto..." />
                    <button type="submit" class="sup-btn">
                        Buscar 🔎
                    </button>
                </div>
            </form>
        </div>

        <div class="inv-table-wrap">
            <table class="table table-striped inv-table align-middle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Stock</th>
                        <th>Mínimo</th>
                        <th>Máximo</th>
                        <th style="width:340px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (BeautyGlam.Abstracciones.ModelosParaUI.InventarioDto item in Model)
                    {
                        <tr>
                            <!-- Producto -->
                            <td>
                                <strong style="color:#5c3b6f;">
                                    @item.nombre
                                </strong>
                            </td>

                            <!-- Stock actual con alerta -->
                            <td>
                                @if (item.stockActual <= item.stockMinimo)
                                {
                                    <span class="inv-chip inv-chip-low">
                                        @item.stockActual 🔴
                                    </span>
                                }
                                else if (item.stockActual <= item.stockMinimo + 2)
                                {
                                    <span class="inv-chip inv-chip-warning">
                                        @item.stockActual ⚠
                                    </span>
                                }
                                else if (item.stockActual >= item.stockMaximo)
                                {
                                    <span class="inv-chip inv-chip-high">
                                        @item.stockActual 📦
                                    </span>
                                }
                                else
                                {
                                    <span class="inv-chip inv-chip-ok">
                                        @item.stockActual ✔
                                    </span>
                                }
                            </td>

                            <td>@item.stockMinimo</td>
                            <td>@item.stockMaximo</td>

                            <!-- Acciones -->
                            <td>
                                <div class="inv-actions">
                                    <a class="btn inv-btn"
                                       href="@Url.Action("EditarStockActual","Inventario", new { id = item.id })">
                                        Editar stock ✏️
                                    </a>

                                    <a class="btn inv-btn inv-btn-soft"
                                       href="@Url.Action("EditarStock","Inventario", new { id = item.id })">
                                        Mín/Máx 📌
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="usr-pagination">
                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <a class="usr-page-link @(i == ViewBag.PaginaActual ? "active" : "")"
                       href="@Url.Action("ListaDeInventario", new { pagina = i, buscar = ViewBag.Buscar })">
                        @i
                    </a>
                }
            </div>
        </div>

    </div>
</section>
