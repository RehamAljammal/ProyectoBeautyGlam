@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.HistorialCompraDto>

@{
    ViewBag.Title = "Historial de Compras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space promo-page">
    <div class="container promo-container">

        <!-- ENCABEZADO -->
        <div class="promo-header text-center mb-4">
            <h2 class="promo-title">Historial de Compras</h2>
            <p class="promo-subtitle">Tus pedidos realizados 🛍️</p>
        </div>

        <!-- LISTADO -->
        <div class="row justify-content-center">

            @if (Model != null && Model.Any())
            {
                foreach (var compra in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="promo-card h-100 p-3 text-center">

                            <h5 style="color:#5c3b6f;">
                                Pedido #@compra.idVenta
                            </h5>

                            <p class="text-muted">
                                📅 @compra.fecha.ToShortDateString()
                            </p>

                            <p>
                                <strong>Total:</strong> ₡ @compra.total
                            </p>

                            <p>
                                <strong>Estado:</strong> @compra.estado
                            </p>

                            <a href="@Url.Action("Detalle","HistorialCompras", new { idVenta = compra.idVenta })"
                               class="promo-btn promo-btn-outline mt-2">
                                Ver detalle 👁
                            </a>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    No tienes compras registradas.
                </div>
            }

        </div>

    </div>
</section>