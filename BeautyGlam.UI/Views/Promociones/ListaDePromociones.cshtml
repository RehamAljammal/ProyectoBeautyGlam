@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.PromocionesDTO>

@{
    ViewBag.Title = "Promociones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .promo-pagination {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 20px;
    }

    .promo-page-link {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        color: #6b4c7a;
        background: #f6f1fb;
        border: 1px solid #eadff3;
    }

        .promo-page-link.active {
            background: linear-gradient(135deg,#ffb7d5,#cdb7ff);
            color: white;
            border: none;
        }

    .promo-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        flex-wrap: nowrap;
    }

        .promo-actions .promo-btn {
            white-space: nowrap;
        }

        .promo-actions .promo-btn {
            min-width: 120px;
            text-align: center;
        }
</style>

<section class="section-space promo-page">
    <div class="container promo-container">

        <div class="promo-header">
            <h2 class="promo-title">Promociones</h2>
            <p class="promo-subtitle">Controla tus descuentos 💖</p>
        </div>

        <div class="promo-card">
            <div class="promo-card-head">
                <div>
                    <span class="promo-badge">Listado</span>
                </div>



                <div class="d-flex gap-2">

                    <a href="@Url.Action("CrearPromociones","Promociones")"
                       class="promo-btn">
                        + Nueva Promoción
                    </a>

                    <a href="@Url.Action("Index","Combos")"
                       class="promo-btn promo-btn-outline">
                        Ver combos
                    </a>

                </div>
            </div>

            <div style="padding:15px;">
                <form method="get" action="@Url.Action("ListaDePromociones","Promociones")">

                    <div class="d-flex gap-2">

                        <input type="text"
                               name="buscar"
                               value="@ViewBag.Buscar"
                               class="form-control"
                               placeholder="Buscar promoción..." />

                        <button type="submit" class="promo-btn">
                            Buscar 🔎
                        </button>

                    </div>

                </form>
            </div>

            <div class="promo-table-wrap table-responsive">
                <table class="table table-striped align-middle promo-table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Descripción</th>
                            <th>Vigencia</th>
                            <th>Estado</th>
                            <th class="text-end" style="width:300px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong style="color:#5c3b6f;">
                                        @item.titulo
                                    </strong>
                                </td>

                                <td>
                                    @item.descripcion
                                </td>

                                <td>
                                    @item.fecha_Inicio.ToString("dd/MM/yyyy")
                                    -
                                    @item.fecha_Fin.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @if (item.estado)
                                    {
                                        <span class="promo-chip promo-chip-ok">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="promo-chip promo-chip-off">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="promo-actions">

                                        <a href="@Url.Action("EditarPromociones","Promociones", new { id = item.id_Promocion })"
                                           class="promo-btn promo-btn-outline promo-btn-sm">
                                            Editar ✏️
                                        </a>

                                        @if (item.estado)
                                        {
                                            <a href="@Url.Action("ActivarDesactivar", "Promociones", new { id = item.id_Promocion })"
                                               class="promo-btn sup-btn-danger sup-btn-sm">
                                                Desactivar 🗑️
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("ActivarDesactivar", "Promociones", new { id = item.id_Promocion })"
                                               class="promo-btn sup-btn-sm">
                                                Activar ✨
                                            </a>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
                <div class="promo-pagination">

                    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                    {
                        <a class="promo-page-link @(i == ViewBag.PaginaActual ? "active" : "")"
                           href="@Url.Action("ListaDePromociones", new { pagina = i, buscar = ViewBag.Buscar })">
                            @i
                        </a>
                    }

                </div>
            </div>

        </div>

    </div>
</section>