@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.ProveedoresDto>

@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .sup-pagination {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 18px;
    }

    .sup-page-link {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        color: #6b4c7a;
        background: #f6f1fb;
        border: 1px solid #eadff3;
        transition: .2s;
    }

        .sup-page-link:hover {
            background: #efe6fa;
        }

        .sup-page-link.active {
            background: linear-gradient(135deg,#ffb7d5,#cdb7ff);
            color: white;
            border: none;
        }

    .sup-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        flex-wrap: nowrap;
    }

        .sup-actions .sup-btn {
            min-width: 120px;
            text-align: center;
            white-space: nowrap;
        }
</style>

<section class="section-space sup-page">
    <div class="container sup-container">

        <div class="sup-header">
            <h2 class="sup-title">Proveedores</h2>
            <p class="sup-subtitle">Administra contactos, estado y datos de compra ✨</p>
        </div>

        <div class="sup-card">
            <div class="sup-card-head">
                <span class="sup-badge">Listado</span>

                <a href="@Url.Action("CrearProveedor","Proveedores")" class="sup-btn">
                    + Agregar Proveedor
                </a>
            </div>

            <div style="padding:15px;">
                <form method="get" action="@Url.Action("ListaDeProveedores","Proveedores")">

                    <div class="d-flex gap-2">

                        <input type="text"
                               name="buscar"
                               value="@ViewBag.Buscar"
                               class="form-control"
                               placeholder="Buscar proveedor..." />

                        <button type="submit" class="sup-btn">
                            Buscar 🔎
                        </button>

                    </div>

                </form>
            </div>

            <div class="sup-table-wrap table-responsive">
                <table class="table table-striped align-middle sup-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th class="text-center" style="width:320px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var proveedor in Model)
                        {
                            <tr>
                                <td>
                                    <strong style="color:#5c3b6f;">@proveedor.nombre</strong>
                                </td>
                                <td>@proveedor.correo</td>
                                <td>@proveedor.telefono</td>
                                <td>
                                    @if (proveedor.estado)
                                    {
                                        <span class="sup-chip sup-chip-ok">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="sup-chip sup-chip-off">Inactivo</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="sup-actions">
                                        <a href="@Url.Action("DetallesDelProveedor","Proveedores", new { id = proveedor.id })"
                                           class="sup-btn sup-btn-soft sup-btn-sm">
                                            Ver 👀
                                        </a>

                                        <a href="@Url.Action("EditarProveedor","Proveedores", new { id = proveedor.id })"
                                           class="sup-btn sup-btn-outline sup-btn-sm">
                                            Editar ✏️
                                        </a>

                                        @if (proveedor.estado)
                                        {
                                            <a href="@Url.Action("EliminarProveedor","Proveedores", new { id = proveedor.id })"
                                               class="sup-btn sup-btn-danger sup-btn-sm">
                                                Desactivar 🗑️
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("EliminarProveedor","Proveedores", new { id = proveedor.id })"
                                               class="sup-btn sup-btn-sm">
                                                Activar ✨
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="sup-pagination">

                    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                    {
                        <a class="sup-page-link @(i == ViewBag.PaginaActual ? "active" : "")"
                           href="@Url.Action("ListaDeProveedores", new { pagina = i, buscar = ViewBag.Buscar })">
                            @i
                        </a>
                    }

                </div>
            </div>

        </div>

    </div>
</section>
