@model BeautyGlam.Abstracciones.ModelosParaUI.TonoDTO

@{
    ViewBag.Title = "Crear tono";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space prod-page">

    <div class="container prod-container">

        <div class="prod-header">
            <h2 class="prod-title">Crear nuevo tono</h2>
            <p class="prod-subtitle">Agrega un tono para productos</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-6">

                <div class="prod-card p-4">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            @Html.LabelFor(m => m.nombre, new { @class = "prod-label" })

                            @Html.TextBoxFor(m => m.nombre,
                                new { @class = "form-control prod-input", placeholder = "Ej: Claro" })

                            @Html.ValidationMessageFor(m => m.nombre)
                        </div>

                        <div class="mb-3">
                            <label class="prod-label">Estado</label>

                            <div>
                                @Html.CheckBoxFor(m => m.estado)
                                <span style="color:#6b4c7a;font-weight:650;">
                                    Activo
                                </span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a href="@Url.Action("Index","Tono")"
                               class="prod-btn prod-btn-soft">
                                Cancelar
                            </a>

                            <button type="submit"
                                    class="prod-btn">
                                Guardar
                            </button>

                        </div>
                    }

                </div>

            </div>
        </div>

    </div>

</section>