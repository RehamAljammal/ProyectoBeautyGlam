@model BeautyGlam.Abstracciones.ModelosParaUI.UsuarioDto

@{
    ViewBag.Title = "Editar perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space inv-page">
    <div class="container inv-container">

        <!-- Header -->
        <div class="inv-header">
            <h2 class="inv-title">Editar perfil ✏️</h2>
            <p class="inv-subtitle">
                Actualiza tu información personal
            </p>
        </div>

        @using (Html.BeginForm("Editar", "Perfil", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.id_Usuario)

            <div class="row justify-content-center">
                <div class="col-lg-8">

                    <div class="inv-filters p-4 rounded-4 bg-white shadow-sm">

                        <div class="row g-4">

                            <!-- Nombre -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Nombre de usuario</label>
                                @Html.TextBoxFor(m => m.nombre,
                                    new
                                    {
                                        @class = "form-control rounded-pill shadow-sm",
                                        required = "required"
                                    })
                                @Html.ValidationMessageFor(m => m.nombre, "", new { @class = "text-danger" })
                            </div>

                            <!-- Apellido -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Apellido</label>
                                @Html.TextBoxFor(m => m.apellido,
                                    new
                                    {
                                        @class = "form-control rounded-pill shadow-sm",
                                        required = "required"
                                    })
                                @Html.ValidationMessageFor(m => m.apellido, "", new { @class = "text-danger" })
                            </div>

                            <!-- Correo -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Correo</label>
                                @Html.TextBoxFor(m => m.correo,
                                    new
                                    {
                                        @class = "form-control rounded-pill shadow-sm",
                                        type = "email",
                                        required = "required"
                                    })
                                @Html.ValidationMessageFor(m => m.correo, "", new { @class = "text-danger" })
                            </div>

                            <!-- Teléfono -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Teléfono</label>
                                @Html.TextBoxFor(m => m.telefono,
                                    new
                                    {
                                        @class = "form-control rounded-pill shadow-sm",
                                        required = "required"
                                    })
                                @Html.ValidationMessageFor(m => m.telefono, "", new { @class = "text-danger" })
                            </div>

                            <!-- Dirección -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Dirección</label>
                                @Html.TextAreaFor(m => m.direccion,
                                    new
                                    {
                                        @class = "form-control rounded-4 shadow-sm",
                                        rows = "2",
                                        required = "required"
                                    })
                                @Html.ValidationMessageFor(m => m.direccion, "", new { @class = "text-danger" })
                            </div>

                        </div>

                        <!-- Acciones -->
                        <div class="mt-4 d-flex justify-content-end gap-2">

                            <a href="@Url.Action("Index","Perfil")"
                               class="btn inv-btn rounded-pill">
                                Cancelar
                            </a>

                            <button type="submit"
                                    class="btn inv-btn rounded-pill">
                                Guardar cambios 💾
                            </button>

                        </div>

                    </div>

                </div>
            </div>
        }

    </div>
</section>