@model BeautyGlam.Abstracciones.ModelosParaUI.UsuarioDto

@{
    ViewBag.Title = "Mi perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space inv-page">
    <div class="container inv-container">

        <!-- Header -->
        <div class="inv-header">
            <h2 class="inv-title">Mi perfil 👤</h2>
            <p class="inv-subtitle">
                Consulta y administra tu información personal
            </p>
        </div>

        <!-- Card perfil -->
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="inv-filters p-4 rounded-4 bg-white shadow-sm">

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nombre</label>
                            <input type="text" class="form-control rounded-pill shadow-sm"
                                   value="@Model.nombre" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Apellido</label>
                            <input type="text" class="form-control rounded-pill shadow-sm"
                                   value="@Model.apellido" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Correo</label>
                            <input type="text" class="form-control rounded-pill shadow-sm"
                                   value="@Model.correo" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Teléfono</label>
                            <input type="text" class="form-control rounded-pill shadow-sm"
                                   value="@Model.telefono" readonly />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Dirección</label>
                            <textarea class="form-control rounded-4 shadow-sm"
                                      rows="2"
                                      readonly>@Model.direccion</textarea>
                        </div>

                    </div>

                    <!-- Acciones -->
                    <div class="mt-4 text-end">
                        <a href="@Url.Action("Editar","Perfil")"
                           class="btn inv-btn rounded-pill">
                            Editar perfil ✏️
                        </a>

                        <a href="@Url.Action("Movimientos","Inventario")"
                           class="btn inv-btn rounded-pill">
                            Seguimiento de producto 📦
                        </a>
                    </div>

                </div>

            </div>
        </div>

    </div>
</section>