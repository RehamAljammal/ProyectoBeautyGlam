@model IEnumerable<BeautyGlam.Abstracciones.ModelosParaUI.WishlistProductoDto>

@{
    ViewBag.Title = "Mi Wishlist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space">
    <div class="container">

        <h2 class="wishlist-title">❤️ Mi Lista de Deseos</h2>

        @if (!Model.Any())
        {
            <div class="wishlist-empty">

                <h4>No tienes productos en tu wishlist</h4>

                <p>Explora nuestros productos y agrega tus favoritos ❤️</p>

                <a href="@Url.Action("Index","Catalogo")"
                   class="wishlist-btn">
                    Ver Productos
                </a>

            </div>
        }
        else
        {

            <div class="wishlist-grid">

                @foreach (var item in Model)
                {

                    <div class="wishlist-card">

                        <img src="@Url.Content("~" + item.imagen)"
                             class="wishlist-img" />

                        <div class="wishlist-info">

                            <h5>@item.nombre</h5>

                            <div class="wishlist-price">
                                ₡ @item.precio
                            </div>

                            <div class="wishlist-actions">

                                <form method="post"
                                      action="@Url.Action("Eliminar","Wishlist")">

                                    <input type="hidden"
                                           name="idWishlist"
                                           value="@item.id_Wishlist" />

                                    <input type="hidden"
                                           name="idProducto"
                                           value="@item.idProducto" />

                                    <button class="cat-btn cat-btn-soft">
                                        Eliminar
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                }

            </div>

        }
        <div class="text-center mb-4">
            <a href="@Url.Action("EnviarWhatsApp","Wishlist")" class="promo-btn">
                Enviar por WhatsApp 📲
            </a>
        </div>
        <!-- PROMOCIONES DE TEMPORADA -->

        @if (ViewBag.Promociones != null)
        {

            <hr style="margin-top:40px">

            <h3 class="wishlist-promo-title">
                🔥 Promociones de temporada
            </h3>

            <p class="wishlist-promo-sub">
                Aprovecha estas ofertas especiales 💖
            </p>

            <div class="wishlist-grid">

                @foreach (var promo in ViewBag.Promociones)
                {

                    <div class="wishlist-card">

                        <img src="@Url.Content("~" + promo.imagen)"
                             class="wishlist-img"
                             alt="@promo.titulo" />

                        <h5>@promo.titulo</h5>

                        <p>@promo.descripcion</p>

                        <div class="wishlist-price">
                            ₡ @promo.totalConDescuento
                        </div>





                    </div>

                }

            </div>

        }

    </div>
</section>

<style>

    .wishlist-title {
        text-align: center;
        color: #5c3b6f;
        font-weight: 700;
        margin-bottom: 30px;
    }

    .wishlist-empty {
        text-align: center;
        margin-top: 40px;
        color: #6b4c7a;
    }

    .wishlist-btn {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 18px;
        background: #5c3b6f;
        color: white;
        border-radius: 12px;
        text-decoration: none;
    }

    .wishlist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-top: 25px;
    }

    .wishlist-card {
        background: white;
        padding: 18px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        text-align: center;
    }

    .wishlist-img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        margin-bottom: 12px;
    }

    .wishlist-price {
        font-weight: 700;
        color: #5c3b6f;
        margin: 8px 0;
    }

    .wishlist-actions {
        margin-top: 10px;
    }

    .wishlist-promo-title {
        text-align: center;
        margin-top: 40px;
        color: #5c3b6f;
        font-weight: 700;
    }

    .wishlist-promo-sub {
        text-align: center;
        color: #6b4c7a;
        margin-bottom: 15px;
    }
</style>
