@model BeautyGlam.Abstracciones.ModelosParaUI.BlogDto

@{
    ViewBag.Title = "Crear publicación";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space inv-page">
    <div class="container inv-container">

        <!-- Header -->
        <div class="inv-header">
            <h2 class="inv-title">Crear publicación 📝</h2>
            <p class="inv-subtitle">
                Redacta y publica un nuevo artículo sobre productos o tips ✨
            </p>
        </div>

        @using (Html.BeginForm("Crear", "Blog", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="row justify-content-center">
                <div class="col-lg-8">

                    <div class="inv-filters p-4 rounded-4 bg-white shadow-sm">

                        <div class="row g-4">

                            <!-- TÍTULO -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Título</label>
                                @Html.TextBoxFor(m => m.titulo,
                                    new { @class = "form-control rounded-pill shadow-sm", required = "required" })
                                @Html.ValidationMessageFor(m => m.titulo, "", new { @class = "text-danger" })
                            </div>

                            <!-- RESUMEN -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Resumen</label>
                                @Html.TextAreaFor(m => m.resumen,
                                    new { @class = "form-control rounded-4 shadow-sm", rows = "3", required = "required" })
                                @Html.ValidationMessageFor(m => m.resumen, "", new { @class = "text-danger" })
                            </div>

                            <!-- CONTENIDO -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Contenido</label>
                                @Html.TextAreaFor(m => m.contenido,
                                    new { @class = "form-control rounded-4 shadow-sm", rows = "6", required = "required" })
                                @Html.ValidationMessageFor(m => m.contenido, "", new { @class = "text-danger" })
                            </div>

                            <!-- IMAGEN -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Imagen</label>

                                <input type="file"
                                       name="imagenArchivo"
                                       class="form-control rounded-pill shadow-sm"
                                       accept="image/*"
                                       onchange="previewImage(this)" />

                                <!-- Vista previa -->
                                <div class="mt-3">
                                    <img id="imgPreview"
                                         src="~/img/blog/default.png"
                                         style="width:160px;height:160px;object-fit:cover;border-radius:16px;border:1px solid #ead7f3;" />
                                </div>
                            </div>

                        </div>

                        <!-- BOTONES -->
                        <div class="mt-4 d-flex justify-content-end gap-2">

                            <a href="@Url.Action("Index","Blog")"
                               class="btn inv-btn rounded-pill btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn inv-btn rounded-pill">
                                Publicar ✅
                            </button>

                        </div>

                    </div>

                </div>
            </div>
        }

    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    document.getElementById("imgPreview").src = e.target.result;
                };

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}