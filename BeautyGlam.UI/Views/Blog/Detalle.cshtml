@model BeautyGlam.Abstracciones.ModelosParaUI.BlogDto

@{
    ViewBag.Title = "Detalle publicación";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var comentarios = ViewBag.Comentarios as List<BeautyGlam.Abstracciones.ModelosParaUI.ComentarioBlogDto>;
}

<section class="section-space inv-page">
    <div class="container inv-container">

        <!-- Header publicación -->
        <div class="inv-header text-center mb-4">
            <h2 class="inv-title">@Model.titulo</h2>
            <p class="inv-subtitle">@Model.resumen</p>
            <small class="text-muted">
                Publicado: @Model.fecha_Publicacion.ToString("dd/MM/yyyy")
            </small>
        </div>

        <!-- Contenido publicación -->
        <div class="inv-filters p-4 rounded-4 bg-white shadow-sm mb-4"
             style="position:relative; padding-left:30px;">

            @* Imagen centrada arriba *@
            @if (!string.IsNullOrEmpty(Model.imagen))
            {
                <div class="text-center mb-4">
                    <img src="@Url.Content("~" + Model.imagen)"
                         class="img-fluid rounded-4 shadow-sm"
                         style="max-width:450px; object-fit:cover;" />
                </div>
            }

            @* Contenido del blog *@
            <div class="mt-3">
                @Html.Raw(Model.contenido)
            </div>

        </div>

        <!-- Comentarios -->
        <div class="inv-header mb-3">
            <h4>Comentarios (@(comentarios?.Count ?? 0))</h4>
        </div>

        <div class="inv-filters p-4 rounded-4 bg-white shadow-sm mb-4"
             style="position:relative; padding-left:30px;">

            @if (comentarios != null && comentarios.Count > 0)
            {
                foreach (var c in comentarios)
                {
                    <div class="mb-3 p-3 border rounded-4 bg-light">
                        <strong>@c.nombreUsuario</strong>
                        <small class="text-muted">
                            (@c.fecha.ToString("dd/MM/yyyy HH:mm"))
                        </small>

                        <p class="mt-2 mb-2">@c.comentario</p>

                        @if ((Session["IdUsuario"] != null && (int)Session["IdUsuario"] == c.id_Usuario) || User.IsInRole("Admin"))
                        {
                            using (Html.BeginForm("DesactivarComentario", "Blog", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("idComentario", c.id_Comentario)
                                @Html.Hidden("idBlog", Model.id_Blog)

                    <button type="submit"
                            class="btn inv-btn rounded-pill">
                        Desactivar
                    </button>
                            }
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No hay comentarios aún.</p>
            }
        </div>

        <!-- Crear comentario -->
        @if (Session["IdUsuario"] != null)
        {
            <div class="inv-header mb-3">
                <h4>Agregar comentario</h4>
            </div>

            <div class="inv-filters p-4 rounded-4 bg-white shadow-sm"
                 style="position:relative; padding-left:30px;">

                @using (Html.BeginForm("CrearComentario", "Blog", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.id_Blog)

                    <div class="form-group mb-3">
                        <textarea name="comentario"
                                  class="form-control rounded-4"
                                  rows="3"
                                  required
                                  placeholder="Escribe tu comentario..."></textarea>
                    </div>

                    <div class="text-end">
                        <button type="submit"
                                class="btn inv-btn rounded-pill">
                                Publicar comentario
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Debes
                <a href="@Url.Action("Login", "Auth")">
                    iniciar sesión
                </a>
                para comentar.
            </div>
        }

    </div>
</section>
</section>