@model BeautyGlam.Abstracciones.ModelosParaUI.OcasionDto

@{
    ViewBag.Title = "Eliminar Ocasión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space sup-page">
    <div class="container sup-container">

        <div class="sup-header">
            <h2 class="sup-title">Eliminar Ocasión</h2>
            <p class="sup-subtitle">Confirma esta acción ⚠️</p>
        </div>

        <div class="sup-card" style="max-width:720px; margin:0 auto;">

            <div class="sup-card-head">
                <span class="sup-badge">Confirmación</span>

                <a href="@Url.Action("Index","Ocasiones")"
                   class="sup-btn sup-btn-soft">
                    Volver
                </a>
            </div>

            <div class="p-4">

                <div class="p-3 rounded-4"
                     style="border:1px solid #f3eaf5; background:#fff;">

                    <div class="small"
                         style="color:#8b7a97; font-weight:800;">
                        Nombre
                    </div>

                    <div style="color:#6b4c7a; font-weight:800;">
                        @Model.nombre
                    </div>

                </div>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.idOcasion)

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <button type="submit" class="sup-btn sup-btn-danger">
                            Desactivar 🗑️
                        </button>

                    </div>
                }

            </div>

        </div>

    </div>
</section>