@model BeautyGlam.Abstracciones.ModelosParaUI.OcasionDto

@{
    ViewBag.Title = "Editar Ocasión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-space sup-page">
    <div class="container sup-container">

        <div class="sup-header">
            <h2 class="sup-title">Editar Ocasión</h2>
            <p class="sup-subtitle">Modifica la ocasión ✏️</p>
        </div>

        <div class="sup-card" style="max-width:720px; margin:0 auto;">

            <div class="sup-card-head">
                <span class="sup-badge">Edición</span>

                <a href="@Url.Action("Index","Ocasiones")"
                   class="sup-btn sup-btn-soft">
                    Volver
                </a>
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(m => m.idOcasion)

                <div class="sup-form">

                    <div class="row g-3">

                        <div class="col-md-8">
                            <label class="form-label sup-label">
                                Nombre
                            </label>

                            @Html.TextBoxFor(m => m.nombre,
                                 new { @class = "form-control sup-input" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label sup-label">
                                Estado
                            </label>

                            @Html.DropDownListFor(
                                     m => m.estado,
                                     new SelectList(
                                         new[] {
                                        new { Value = true, Text = "Activo" },
                                        new { Value = false, Text = "Inactivo" }
                             },
                                         "Value",
                                         "Text",
                                         Model.estado
                                     ),
                                     new { @class = "form-control sup-select" }
                                 )
                        </div>

                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <button type="submit" class="sup-btn">
                            Guardar cambios ✨
                        </button>

                    </div>

                </div>
            }

        </div>

    </div>
</section>