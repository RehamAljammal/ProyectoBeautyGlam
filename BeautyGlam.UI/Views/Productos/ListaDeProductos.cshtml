@model List<BeautyGlam.Abstracciones.ModelosParaUI.ProductosDTO>

@{
    ViewBag.Title = "Gestión de Productos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .prod-pagination {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 20px;
    }

    .prod-page-link {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        color: #6b4c7a;
        background: #f6f1fb;
        border: 1px solid #eadff3;
    }

        .prod-page-link.active {
            background: linear-gradient(135deg,#ffb7d5,#cdb7ff);
            color: white;
            border: none;
        }

    .prod-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        flex-wrap: nowrap;
    }

        .prod-actions .prod-btn {
            white-space: nowrap;
        }

        .prod-actions .prod-btn {
            min-width: 120px;
            text-align: center;
        }
</style>

<section class="section-space prod-page">
    <div class="container">

        <!-- Encabezado -->
        <div class="bg-white rounded-4 shadow-sm p-4 mb-4">

            <form id="filtrosForm">

                <div class="row g-3">

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Categoría
                        </label>
                        @Html.DropDownList("idCategoria",
                            (SelectList)ViewBag.Categorias,
                            "Todas",
                            new { @class = "form-control rounded-pill" })
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Tono
                        </label>
                        <select name="tono" class="form-control rounded-pill">
                            <option value="">Todos</option>
                            <option>Claro</option>
                            <option>Medio</option>
                            <option>Oscuro</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Tipo de piel
                        </label>
                        <select name="tipoPiel" class="form-control rounded-pill">
                            <option value="">Todos</option>
                            <option>Seca</option>
                            <option>Grasa</option>
                            <option>Mixta</option>
                            <option>Sensible</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Marca
                        </label>
                        @Html.DropDownList("idMarca",
                            (SelectList)ViewBag.Marcas,
                            "Todas",
                            new { @class = "form-control rounded-pill" })
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Precio mín
                        </label>
                        <input type="number"
                               name="precioMin"
                               class="form-control rounded-pill" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small d-block mb-1">
                            Precio máx
                        </label>
                        <input type="number"
                               name="precioMax"
                               class="form-control rounded-pill" />
                    </div>

                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">

                    <button type="button"
                            id="btnFiltrar"
                            class="prod-btn"
                            style="padding:10px 28px;border-radius:999px;">
                        FILTRAR 🔍
                    </button>

                </div>

            </form>

        </div>



        <div style="padding:15px;">
            <form method="get" action="@Url.Action("ListaDeProductos","Productos")">

                <div class="d-flex gap-2">

                    <input type="text"
                           name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control"
                           placeholder="Buscar producto..." />

                    <button type="submit" class="sup-btn">
                        Buscar 🔎
                    </button>

                </div>

            </form>
        </div>

        <!-- ================= CARD LISTA ================= -->
        <div class="bg-white rounded-4 shadow-sm p-3">

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Marca</th>
                            <th>Proveedor</th>
                            <th>Precio</th>
                            <th>Estado</th>
                            <th>Tono</th>
                            <th>Tipo piel</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody id="tablaProductos">

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    No se encontraron productos con esos filtros 😔
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <img src="@(string.IsNullOrEmpty(item.imagen)
                                        ? Url.Content("~/Content/img/no-image.png")
                                        : (item.imagen.StartsWith("http")
                                            ? item.imagen
                                            : Url.Content("~" + item.imagen)))"
                                             style="width:46px;height:46px;object-fit:cover;border-radius:8px;" />
                                    </td>

                                    <td>
                                        <strong style="color:#5c3b6f;">@item.nombre</strong>
                                        <div class="small text-muted">
                                            @item.descripcion
                                        </div>
                                    </td>

                                    <td>@item.nombreCategoria</td>
                                    <td>@item.nombreMarca</td>
                                    <td>@item.nombreProveedor</td>
                                    <td>₡ @item.precio</td>

                                    <td>
                                        @if (item.estado)
                                        {
                                            <span class="prod-chip prod-chip-ok">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="prod-chip prod-chip-off">Inactivo</span>
                                        }
                                    </td>

                                    <td>@item.tono</td>
                                    <td>@item.tipoPiel</td>

                                    <td class="text-end">
                                        <div class="d-inline-flex gap-1">

                                            <a href="@Url.Action("DetallesDelProducto","Productos", new { id = item.id })"
                                               class="prod-btn prod-btn-soft prod-btn-sm">
                                                Ver
                                            </a>

                                            <a href="@Url.Action("EditarProducto","Productos", new { id = item.id })"
                                               class="prod-btn prod-btn-outline prod-btn-sm">
                                                Editar
                                            </a>

                                            @if (item.estado)
                                            {
                                                <a href="@Url.Action("ActivarDesactivarProducto", "Productos", new { id = item.id })"
                                                   class="prod-btn prod-btn-danger prod-btn-sm">
                                                    Desactivar
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("ActivarDesactivarProducto", "Productos", new { id = item.id })"
                                                   class="prod-btn prod-btn-sm">
                                                    Activar
                                                </a>
                                            }

                                        </div>
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

                <div class="prod-pagination">

                    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                    {
                        <a class="prod-page-link @(i == ViewBag.PaginaActual ? "active" : "")"
                           href="@Url.Action("ListaDeProductos", new { pagina = i, buscar = ViewBag.Buscar })">
                            @i
                        </a>
                    }

                </div>

            </div>

        </div>

        <div class="d-flex justify-content-end mt-4">

            <a href="@Url.Action("CrearProducto","Productos")"
               class="prod-btn"
               style="padding:12px 26px;border-radius:999px;">
                + Agregar producto
            </a>

        </div>

    </div>
</section>


<script>

    const form = document.getElementById("filtrosForm");
    const btnFiltrar = document.getElementById("btnFiltrar");
    const btnLimpiar = document.getElementById("btnLimpiar");

    function aplicarFiltros() {

        const params = new URLSearchParams(new FormData(form)).toString();

        fetch('@Url.Action("FiltrarProductos", "Productos")?' + params)
            .then(r => r.text())
            .then(html => {
                document.getElementById("tablaProductos").innerHTML = html;
            });
    }

    function limpiarFiltros() {
        form.reset();
        aplicarFiltros();
    }

    form.addEventListener("change", aplicarFiltros);
    btnFiltrar.addEventListener("click", aplicarFiltros);
    btnLimpiar.addEventListener("click", limpiarFiltros);

</script>